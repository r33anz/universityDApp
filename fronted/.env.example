# Protocolo de la API (http o https)
REACT_APP_API_PROTOCOL=http

# Host de la API
REACT_APP_API_HOST=localhost

# Puerto de la API
REACT_APP_API_PORT=5000

# Dirección de la wallet de ejemplo
REACT_APP_WALLET_ADDRESS=0xYourWalletAddress

# Dirección del contrato principal
REACT_APP_CONTRACT_ADDRESS=0xYourContractAddress

# Dirección del contrato NFT
REACT_APP_NFT_ADDRESS=0xYourNFTContractAddress