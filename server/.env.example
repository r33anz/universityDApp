# ---------------------------------------------------------------------------
# Server / HTTP
# ---------------------------------------------------------------------------
PORT=5000
# Origin allowed by CORS and Socket.io. Use the frontend URL in prod; "*" in dev.
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# Base de datos (Postgres)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=changeme
DB_NAME=KardexManagement

# ---------------------------------------------------------------------------
# Blockchain
# ---------------------------------------------------------------------------
# Private key del wallet emisor (NUNCA commitear la real)
PRIVATE_KEY=

# RPC URL. Default: BSC Testnet. Para Hardhat local: http://localhost:8545
RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# Contratos desplegados
CONTRACT_ADDRESS_PROXY_MANAGEMENT_CREDENTIAL=0xYourProxyManagementCredentialAddress
CONTRACT_ADDRESS_NFT=0xYourNFTContractAddress

# Block explorer (para enlaces de verificación en respuestas)
SCANNER_BASE_URL=https://testnet.bscscan.com
BSCSCAN_API_KEY=your-bscscan-api-key

# ---------------------------------------------------------------------------
# IPFS (Kubo daemon)
# ---------------------------------------------------------------------------
IPFS_API=http://127.0.0.1:5001
IPFS_GATEWAY=http://localhost:8080/ipfs/
IPFS_DEFAULT_KARDEX_IMAGE=QmYourDefaultKardexImageHash

# ---------------------------------------------------------------------------
# Email (Gmail SMTP via nodemailer)
# ---------------------------------------------------------------------------
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-gmail-app-password
# Destinatario admin que recibe los códigos SIS cuando se atienden notificaciones
ADMIN_EMAIL=admin@example.com
